# =============================================================================
# GitHub Actions — Secrets and Variables
# =============================================================================
#
# These are NOT .env files. Add them in the GitHub UI:
#   Repo → Settings → Secrets and variables → Actions
#
# Used by: .github/workflows/sn-sync.yml
# Does NOT run on Vercel — this is where Playwright sync actually executes.
#
# =============================================================================


# -----------------------------------------------------------------------------
# SECRETS (Settings → Secrets → New repository secret)
# -----------------------------------------------------------------------------

# Same Neon DATABASE_URL as Vercel
DATABASE_URL=

# JSON array from: bun sn:export-cookies
# Refresh after login timeout or monthly. Admin setup:
#   vercel env pull .env.local
#   bun sn:sync --login
#   bun sn:export-cookies | gh secret set LINKEDIN_SESSION_COOKIES --repo owner/lnkr
LINKEDIN_SESSION_COOKIES=


# -----------------------------------------------------------------------------
# VARIABLES (Settings → Variables → New repository variable)
# Optional — defaults apply if unset
# -----------------------------------------------------------------------------

# Max profiles scraped per workflow run (default: 50)
# DAILY_SCRAPE_LIMIT=50

# Delay between profile visits in ms (defaults: 4000 / 10000)
# SCRAPE_MIN_DELAY_MS=4000
# SCRAPE_MAX_DELAY_MS=10000

# Recent posts read per profile (default: 5)
# MAX_POSTS_PER_PROFILE=5


# -----------------------------------------------------------------------------
# SET IN WORKFLOW (do not add manually — sn-sync.yml sets these)
# -----------------------------------------------------------------------------

# SCRAPE_HEADLESS=true
