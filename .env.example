# Core (Vercel + local)
DATABASE_URL=
ENRICHMENT_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- GitHub Actions sync (Vercel dashboard → trigger workflow) ---
# Fine-grained PAT: repo access + Actions: Read and write
# GITHUB_SYNC_TOKEN=
# owner/repo — same repo that hosts .github/workflows/sn-sync.yml
# GITHUB_REPO=
# Optional: workflow filename (default sn-sync.yml)
# GITHUB_SYNC_WORKFLOW=sn-sync.yml
# Optional: branch/ref for workflow_dispatch (default main, or VERCEL_GIT_COMMIT_REF)
# GITHUB_SYNC_REF=main
# Set to true after LINKEDIN_SESSION_COOKIES is stored in GitHub Secrets
# GITHUB_SYNC_SESSION_CONFIGURED=true

# --- GitHub Secrets (repo → Settings → Secrets; not in Vercel) ---
# Same Neon connection string as Vercel
# DATABASE_URL=
# JSON from `bun sn:export-cookies` (admin refreshes monthly or on login failure)
# LINKEDIN_SESSION_COOKIES=

# --- Optional GitHub repo Variables (non-secret; mirror scraper tuning) ---
# DAILY_SCRAPE_LIMIT=50
# SCRAPE_MIN_DELAY_MS=4000
# SCRAPE_MAX_DELAY_MS=10000
# MAX_POSTS_PER_PROFILE=5

# --- Local sync only (not needed when using GitHub Actions) ---
# BROWSER_PROFILE_DIR=~/.lnkr/browser-profile
# SCRAPE_HEADLESS=false
