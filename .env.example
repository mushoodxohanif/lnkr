# PostgreSQL (Neon recommended)
DATABASE_URL="postgresql://user:password@host:5432/lnkr?sslmode=verify-full"

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Company enrichment (DataLayer or Apollo)
ENRICHMENT_PROVIDER="datalayer"
ENRICHMENT_API_KEY=""

# Custom Apify actor (Crawlee + Playwright + Chrome) — see lib/integrations/apify-contract.ts
APIFY_TOKEN=""
APIFY_ACTOR_ID="your-username/your-lnkr-sn-actor"
APIFY_FALLBACK="false"
APIFY_LI_AT=""
APIFY_TIMEOUT_SECS="600"
APIFY_HEADLESS="false"
APIFY_INPUT_JSON=""

# Optional API key for /api routes (omit for local-only mode)
API_KEY=""

# Scraper safety defaults (also sent to your Apify actor as minDelayMs / maxDelayMs / maxPostsPerProfile)
DAILY_SCRAPE_LIMIT="50"
DAILY_CRON="0 7 * * *"
TIMEZONE="America/New_York"
SCRAPE_MIN_DELAY_MS="4000"
SCRAPE_MAX_DELAY_MS="10000"
MAX_POSTS_PER_PROFILE="5"