generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id               String   @id @default(cuid())
  productName      String
  valueProps       Json     @default("[]")
  targetIndustries Json     @default("[]")
  targetPersonas   Json     @default("[]")
  caseStudies      Json     @default("[]")
  pricingTierHints String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ICPCriteria {
  id              String   @id @default(cuid())
  titles          Json     @default("[]")
  seniorityLevels Json     @default("[]")
  companySizeMin  Int?
  companySizeMax  Int?
  industries      Json     @default("[]")
  techStack       Json     @default("[]")
  geo             Json     @default("[]")
  exclusionRules  Json     @default("{}")
  weights         Json     @default("{}")
  fitThreshold    Int      @default(45)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Lead {
  id                  String             @id @default(cuid())
  linkedInUrl         String             @unique
  name                String
  headline            String?
  title               String?
  company             String?
  location            String?
  snListSource        String?
  rawProfileSnapshot  Json?
  recentPosts         Json?
  status              LeadStatus         @default(NEW)
  notes               String?            @db.Text
  notesUpdatedAt      DateTime?
  scrapedAt           DateTime?
  snoozedUntil        DateTime?
  companyEnrichmentId String?
  companyEnrichment   CompanyEnrichment? @relation(fields: [companyEnrichmentId], references: [id])
  scores              LeadScore[]
  generatedContent    GeneratedContent[]
  draftChat           DraftChat?
  dailyBatchEntries   DailyBatchLead[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([scrapedAt])
}

enum LeadStatus {
  NEW
  QUALIFIED
  ARCHIVED
  SENT
  SKIPPED
  SNOOZED
}

model CompanyEnrichment {
  id            String   @id @default(cuid())
  domain        String   @unique
  companyName   String?
  employeeCount Int?
  industry      String?
  funding       Json?
  techStack     Json?
  signals       Json?
  enrichedAt    DateTime @default(now())
  leads         Lead[]
}

model LeadScore {
  id               String       @id @default(cuid())
  leadId           String
  lead             Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fitPercent       Float
  dimensionScores  Json         @default("{}")
  fitReasons       Json         @default("[]")
  disqualifiers    Json         @default("[]")
  painPoints       Json         @default("[]")
  recommendedOffer String?
  timingSignal     TimingSignal @default(WARM)
  priorityRank     Int?
  scoredAt         DateTime     @default(now())

  @@index([leadId, scoredAt])
  @@index([fitPercent])
  @@index([priorityRank])
}

enum TimingSignal {
  HOT
  WARM
  COLD
}

model GeneratedContent {
  id                   String        @id @default(cuid())
  leadId               String
  lead                 Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  warmingComment       String?
  connectionNote       String?       @db.VarChar(300)
  painPoints           Json?
  personalizationHooks Json?
  status               ContentStatus @default(DRAFT)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([leadId])
}

enum ContentStatus {
  DRAFT
  COPIED
  SENT
}

model DraftChat {
  id                 String             @id @default(cuid())
  leadId             String             @unique
  lead               Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  generatedContentId String?
  warmingComment     String?            @db.Text
  connectionNote     String?            @db.VarChar(300)
  messages           DraftChatMessage[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model DraftChatMessage {
  id        String        @id @default(cuid())
  chatId    String
  chat      DraftChat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      DraftChatRole
  content   String        @db.Text
  createdAt DateTime      @default(now())

  @@index([chatId, createdAt])
}

enum DraftChatRole {
  USER
  ASSISTANT
}

model DailyBatch {
  id           String           @id @default(cuid())
  date         DateTime         @unique @db.Date
  top50LeadIds Json             @default("[]")
  runMetadata  Json?
  leads        DailyBatchLead[]
  createdAt    DateTime         @default(now())
}

model DailyBatchLead {
  id           String     @id @default(cuid())
  dailyBatchId String
  dailyBatch   DailyBatch @relation(fields: [dailyBatchId], references: [id], onDelete: Cascade)
  leadId       String
  lead         Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  rank         Int

  @@unique([dailyBatchId, leadId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model SnListConfig {
  id           String    @id @default(cuid())
  name         String
  url          String    @unique
  enabled      Boolean   @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model DoNotContact {
  id          String   @id @default(cuid())
  linkedInUrl String?  @unique
  email       String?  @unique
  reason      String?
  createdAt   DateTime @default(now())
}

model PromptTemplate {
  id           String   @id @default(cuid())
  key          String   @unique
  instructions String   @default("")
  updatedAt    DateTime @updatedAt
}
